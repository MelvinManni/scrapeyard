# Server
PORT=3000
NODE_ENV=development

# Auth
JWT_SECRET=change-me-in-production
SESSION_DAYS=14

# Initial admin (created on first boot if no users exist)
ADMIN_EMAIL=admin@acme.io
ADMIN_PASSWORD=admin
ADMIN_NAME=Admin

# Database file
DB_PATH=./data/scrape-yard.db

# Redis (BullMQ). Optional — if unset, jobs run on an in-process scheduler instead.
REDIS_URL=

# Scraper
USER_AGENT=ScrapeYard/1.0 (+https://github.com/scrape-yard)
DEFAULT_LOCALE=en-US
DEFAULT_REGION=US

# Optional Anthropic key — if set, filter prompts are evaluated by Claude.
# Without it, filter prompts fall back to keyword/regex matching.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
