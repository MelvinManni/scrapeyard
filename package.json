{
  "name": "scrape-yard",
  "version": "1.0.0",
  "description": "Internal scraping tool: keyword-driven cron scrapes with prompt-filtered results",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "prisma migrate deploy && node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/queue/worker.js",
    "all": "node src/server.js",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.21.2",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "playwright": "^1.48.2",
    "undici": "^6.20.1"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
